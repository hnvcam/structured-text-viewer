    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@electron/*": ["./electron/*"]
    }
  },
  "include": ["electron", "vite.config.ts"]
}
